{
  "name": "behold",
  "version": "0.1.0-alpha.0",
  "description": "Minecraft bot using Mineflayer with OpenRouter chat replies",
  "private": true,
  "main": "src/index.js",
  "license": "UNLICENSED",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "start": "npm run build && node dist/src/index.js",
    "swarm": "npm run world -- start",
    "dev": "ts-node --transpile-only src/index.ts",
    "behold": "ts-node --transpile-only src/cli/behold.ts",
    "agent:stdio": "ts-node --transpile-only src/cli/main.ts agent --stdio",
    "tools": "ts-node --transpile-only src/cli/main.ts tools --json",
    "console": "ts-node --transpile-only src/tui/repl.ts",
    "server": "ts-node --transpile-only scripts/server.ts",
    "pilot": "node scripts/patch-prismarine-viewer.js && ts-node --transpile-only scripts/pilot.ts",
    "native": "ts-node --transpile-only scripts/native-client.ts",
    "play": "ts-node --transpile-only scripts/play.ts",
    "world": "npm run build && node dist/scripts/world-runner.js",
    "place:epoch": "npm run build && node dist/scripts/place-epoch.js",
    "proof:owned-world": "npm run build && node dist/scripts/owned-world-proof.js",
    "proof:verify-owned-world": "npm run build && node dist/scripts/verify-owned-world-proof.js",
    "proof:owned-world-model": "npm run build && node dist/scripts/owned-world-model-proof.js",
    "proof:owned-world-population": "npm run build && node dist/scripts/owned-world-population-proof.js",
    "proof:owned-world-handoff": "npm run build && node dist/scripts/owned-world-handoff-proof.js",
    "proof:owned-world-cache": "npm run build && node dist/scripts/owned-world-cache-proof.js",
    "proof:owned-world-project": "npm run build && node dist/scripts/owned-world-project-proof.js",
    "proof:owned-world-portfolio": "npm run build && node dist/scripts/owned-world-portfolio.js",
    "proof:native-body": "npm run build && node dist/scripts/native-body-conformance.js",
    "proof:native-attention": "npm run build && node dist/scripts/native-attention-conformance.js",
    "proof:native-doorway": "npm run build && node dist/scripts/native-doorway-conformance.js",
    "proof:resident-recovery": "npm run build && node dist/scripts/resident-recovery-witness.js",
    "proof:resident-recovery-live": "npm run build && node dist/scripts/resident-recovery-live.js",
    "eval:mind-differential": "npm run build && node dist/scripts/mind-differential.js",
    "eval:mind-extract": "npm run build && node dist/scripts/extract-mind-request.js",
    "eval:mind-pair": "npm run build && node dist/scripts/mind-compare.js",
    "viewer:patch": "node scripts/patch-prismarine-viewer.js",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit && eslint .",
    "format": "prettier -w .",
    "check": "npm run lint && npm test",
    "prepare": "husky",
    "cli": "ts-node --transpile-only src/tools/readline.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@ax-llm/ax": "23.0.0",
    "@deepfates/lync": "^0.3.0",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.5",
    "minecraft-data": "^3.66.0",
    "mineflayer": "^4.37.1",
    "mineflayer-pathfinder": "^2.4.5",
    "prismarine-viewer": "^1.33.0",
    "vec3": "^0.1.10",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^22.7.7",
    "eslint": "^9.11.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "**/*.{js,jsx}": [
      "eslint --fix --max-warnings=0"
    ],
    "**/*.{js,ts,jsx,tsx,json,md}": [
      "prettier -w"
    ]
  }
}
