{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}

