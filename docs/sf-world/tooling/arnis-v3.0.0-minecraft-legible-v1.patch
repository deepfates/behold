+#[derive(Clone, Copy, PartialEq, Eq, Debug, clap::ValueEnum)]
+pub enum CartographyPolicy {
+    #[value(name = "literal-v1")]
+    LiteralV1,
+    #[value(name = "minecraft-legible-v1")]
+    MinecraftLegibleV1,
+}
+
+impl CartographyPolicy {
+    pub fn tree_size_filter(self) -> crate::trees::tree_library::SizeFilter {
+        use crate::trees::tree_library::SizeFilter;
+        match self {
+            Self::LiteralV1 => SizeFilter::default(),
+            Self::MinecraftLegibleV1 => SizeFilter {
+                small: true,
+                medium: true,
+                big: true,
+                tall: false,
+                giant: false,
+            },
+        }
+    }
+
+    pub fn tree_spacing_bonus(self) -> i32 {
+        match self {
+            Self::LiteralV1 => 0,
+            Self::MinecraftLegibleV1 => 2,
+        }
+    }
+
+    pub fn tree_density_multiplier(self) -> f64 {
+        match self {
+            Self::LiteralV1 => 1.0,
+            Self::MinecraftLegibleV1 => 0.70,
+        }
+    }
+}
