# Server
SERVER_HOST=localhost
SERVER_PORT=25565

# Auth
MINECRAFT_USERNAME=BeholdBot
MINECRAFT_PASSWORD=
MINECRAFT_AUTH=offline

# Agent
AGENT_TICK_MS=4000
# Newly urgent bodily decisions are aborted after this wall-clock budget.
BEHOLD_URGENT_DECISION_TIMEOUT_MS=5000

# Viewer (prismarine-viewer)
# Enable a local web viewer so you can watch the bot without logging into Minecraft.
VIEWER_ENABLED=1
VIEWER_PORT=3007
VIEWER_FIRST_PERSON=1

# OpenRouter
OPENROUTER_API_KEY=
# Optional overrides/metadata
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_REFERER=https://your.site (recommended)
# OPENROUTER_TITLE=Behold Bot (optional)

# Model slug (OpenRouter)
# Pin an exact OpenRouter slug for reproducible runs.
LLM_MODEL=google/gemini-3.5-flash
# Optional separately authorized bodily-urgency tier.
LLM_URGENT_MODEL=openai/gpt-5.6-luna
